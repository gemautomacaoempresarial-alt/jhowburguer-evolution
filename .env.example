# Aplicação principal: https://jhowburgueratender.discloud.app
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
TRUST_PROXY=1

# PostgreSQL da Discloud pela VLAN privada.
DB_CLIENT=postgres
PGHOST=jhowburguer-db
PGPORT=5432
PGUSER=USUARIO_FORNECIDO_PELA_DISCLOUD
PGPASSWORD=SENHA_FORNECIDA_PELA_DISCLOUD
PGDATABASE=NOME_DO_BANCO_FORNECIDO_PELA_DISCLOUD
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=false

# Alternativa: use uma URL completa e remova/comente PGHOST, PGPORT, PGUSER, PGPASSWORD e PGDATABASE.
# DATABASE_URL=postgresql://USUARIO:SENHA@jhowburguer-db:5432/NOME_DO_BANCO

# Endereços públicos definidos para este projeto.
APP_ORIGIN=https://jhowburgueratender.discloud.app
PUBLIC_SITE_URL=https://jhowburguerpedidos.discloud.app

# Gere duas chaves diferentes com: npm run generate-secrets
JWT_SECRET=COLE_UMA_CHAVE_ALEATORIA_COM_PELO_MENOS_32_CARACTERES
APP_ENCRYPTION_KEY=COLE_OUTRA_CHAVE_ALEATORIA_COM_PELO_MENOS_32_CARACTERES

# Administrador criado somente na primeira inicialização do banco de produção.
INITIAL_ADMIN_NAME=Administrador Jhow Burguer
INITIAL_ADMIN_EMAIL=SEU_EMAIL_DE_LOGIN
INITIAL_ADMIN_PASSWORD=CRIE_UMA_SENHA_FORTE_COM_PELO_MENOS_12_CARACTERES
INITIAL_COMPANY_NAME=Jhow Burguer

BACKUP_DIR=./backups

# Integração Evolution API pela VLAN privada da Discloud.
# A única variável secreta é EVOLUTION_API_KEY.
EVOLUTION_BASE_URL=http://jhowburguer-evolution:8080
EVOLUTION_API_KEY=COLE_A_MESMA_CHAVE_AUTHENTICATION_API_KEY_DA_EVOLUTION
EVOLUTION_INSTANCE=jhowburguer
EVOLUTION_WEBHOOK_BASE_URL=http://jhowburguer-atender:8080
APP_PUBLIC_URL=https://jhowburgueratender.discloud.app


# Revisor de produtos com Gemini.
# Nunca coloque a chave no GitHub. Cadastre-a somente nas variáveis da Discloud.
GEMINI_API_KEY=COLE_AQUI_A_NOVA_CHAVE_DO_GOOGLE_AI_STUDIO
GEMINI_PROJECT_ID=gen-lang-client-0592189245
GEMINI_MODEL=gemini-2.5-flash-lite
# Opcional: modelo usado nas respostas conversacionais. Se vazio, usa GEMINI_MODEL.
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=8000
